DJANGO_ENV=prod
DJANGO_SETTINGS_MODULE=core.settings
SECRET_KEY=change-me
ALLOWED_HOSTS=your-render-service.onrender.com
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://*.vercel.app
USE_REDIS=false
DEFAULT_FROM_EMAIL=votre-email@gmail.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_d_application
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
